# Microsoft Graph — shared mailbox O365
# App enregistrée dans Azure AD avec la permission Mail.ReadWrite (Application)
PARSEDMARC_MSGRAPH_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PARSEDMARC_MSGRAPH_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PARSEDMARC_MSGRAPH_MAILBOX=dmarc@example.com
# Certificat combiné (clé privée + cert) encodé en base64 :
# PARSEDMARC_MSGRAPH_CERT_B64=$(base64 -w0 certs/parsedmarc-combined.pem)
PARSEDMARC_MSGRAPH_CERT_B64=

# Grafana
GRAFANA_PORT=3000
GRAFANA_PASSWORD=changeme

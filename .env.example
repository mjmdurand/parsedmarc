# Microsoft Graph — shared mailbox O365
# App enregistrée dans Azure AD avec la permission Mail.Read (Application)
PARSEDMARC_MSGRAPH_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PARSEDMARC_MSGRAPH_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PARSEDMARC_MSGRAPH_THUMBPRINT=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
PARSEDMARC_MSGRAPH_MAILBOX=dmarc@example.com

# Kibana — optionnel, expose l'interface web
KIBANA_HOST=127.0.0.1
KIBANA_PORT=5601

# Elasticsearch — optionnel, expose le port pour debug
ES_HOST=127.0.0.1
ES_PORT=9200
